# /etc/r/config.yaml — общий конфиг с TUI-скриптом `r`
# НИКОГДА не пуши этот файл в git! Содержит пароль SSH ко всем роутерам.
# Права: chmod 600, владелец root

# ============================================================
# SSH-подключение к роутерам (через frps loopback)
# ============================================================

ssh:
  host: "127.0.0.1"
  user: "root"
  password: "PASTE_ROUTER_ROOT_PASSWORD_HERE"
  connect_timeout: 8

# ============================================================
# Диапазоны портов, которые слушает FRPS на loopback
# ============================================================

web_port_range: [10001, 10099]      # LuCI (web)
ssh_port_range: [11001, 11099]      # SSH (11XXX, последние 2 цифры = id)

# ============================================================
# Ярлыки роутеров (редактируется командами бота и `r`)
# Формат: idNN: "Имя владельца"
# Закомментированные строки (# idNN: свободный) — свободные слоты
# ============================================================

overrides:
  # id01: "ASHOT"
  # id02: "Dacha"
  # ...

# ============================================================
# Пути (не трогать без нужды)
# ============================================================

paths:
  log_file: "/var/log/routers.log"
  checks_dir: "/var/log/r-checks"
