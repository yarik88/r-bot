+def _owner_short_map(db: DB, rids: list[str]) -> dict[str, str]:
+    """Собирает {rid → 'owner4'} для подписи на компактной кнопке.
+    Берётся первый по сортировке по tg_id (стабильно). Если владельцев нет —
